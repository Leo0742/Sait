{
  "name": "russian-house-event-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for Russian House universal event platform",
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "build": "pnpm -r --filter ./packages/* --filter ./services/* --filter ./apps/mobile-bff run build",
    "dev": "pnpm -r --parallel --filter ./services/* run dev",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "compose:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "compose:down": "docker compose -f infra/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "eslint": "^9.33.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
